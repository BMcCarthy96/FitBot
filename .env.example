# Get your API key at https://console.anthropic.com/
EXPO_PUBLIC_ANTHROPIC_API_KEY=your_api_key_here

# Google OAuth client ID + secret (Web application type from Google Cloud Console)
# Authorized redirect URI to add in GCC: https://auth.expo.io/@bmccarthy96/health-food-tracker
# Also add your Gmail as a test user in GCC → OAuth consent screen → Test users
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=

# Facebook App ID from Meta Developer Console (developers.facebook.com)
# Add "auth.expo.io" as a valid OAuth redirect domain in your app settings
EXPO_PUBLIC_FACEBOOK_APP_ID=
